# Database Configuration
# Path to SQLite database file
DB_PATH=./data/events.db

# API Server Configuration
# API server bind address (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0
# API server port
API_PORT=8000

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# YOLOv8 Model Configuration
# Path to YOLOv8 model file (e.g., yolov8n.pt, yolov8s.pt, yolov8m.pt)
YOLO_MODEL_PATH=./models/yolov8n.pt
# Detection confidence threshold (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.5

# Person Tracker Configuration
# Maximum frames to keep track alive without detection
TRACKER_MAX_AGE=30

# Zone Configuration
# Path to zone configuration JSON file
ZONE_CONFIG_PATH=./config/zones.json

# Store Configuration
# Default store ID for video processing
STORE_ID=store_001
